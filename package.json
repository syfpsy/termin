{
  "name": "phosphor-motion-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx watch server/director.ts",
    "build": "tsc -b && vite build",
    "test:engine": "tsx scripts/engine-smoke.ts",
    "typecheck": "tsc -b",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.64.0",
    "lucide-react": "^0.468.0",
    "openai": "^6.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
