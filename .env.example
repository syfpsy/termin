# AI director provider. Supported: mock, anthropic, openrouter, deepseek, openai.
PHOSPHOR_AI_PROVIDER=mock

# Recommended default for Phosphor's short DSL-editing director loop.
# Official Anthropic model docs currently list Claude Sonnet 4 as the balanced default
# and Claude Opus 4.1 as the premium option.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional server-side defaults. Users can also enter keys in the Admin panel,
# which stores them in the browser and sends them per request.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI is supported as a first-class alternative. Official model docs currently
# list GPT-5.2 among the strongest coding/agentic models.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

PHOSPHOR_API_PORT=8787
